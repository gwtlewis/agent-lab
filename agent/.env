# Ollama Configuration (Local)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# OpenAI Configuration (Remote - optional)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4

# Agent Configuration
# Set to "ollama" to use local Ollama models via /api/chat
# Set to "openai" to use OpenAI API
LLM_PROVIDER=ollama

# Database Configuration (for RAG)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# RAG Configuration
ENABLE_RAG=true
